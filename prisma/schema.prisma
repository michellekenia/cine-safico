generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScrapedMovie {
  id                 String              @id @default(cuid())
  slug               String              @unique
  title              String
  alternativeTitles  String[]            @default([])
  originalTitle      String?
  alternativeTitlePt String?
  releaseDate        String?
  director           String?
  synopsisEn         String?
  synopsisPt         String?
  posterImage        String?
  duration           String?
  rating             String?
  scrapedAt          DateTime            @default(now())
  countryPt          String[]
  genresPt           String[]
  languagePt         String[]
  streamingServices  StreamingService[]
  country            Country[]           @relation("CountryToScrapedMovie")
  genres             Genre[]             @relation("GenreToScrapedMovie")
  language           Language[]          @relation("LanguageToScrapedMovie")
  streamingPlatforms StreamingPlatform[] @relation("ScrapedMovieToStreamingPlatform")
}

model Genre {
  id         String         @id @default(cuid())
  nome       String         @unique
  nomePt     String?
  slug       String         @unique
  isFeatured Boolean        @default(false)
  movies     ScrapedMovie[] @relation("GenreToScrapedMovie")
}

model Country {
  id     String         @id @default(cuid())
  nome   String         @unique
  nomePt String?
  slug   String         @unique
  movies ScrapedMovie[] @relation("CountryToScrapedMovie")
}

model Language {
  id     String         @id @default(cuid())
  nome   String         @unique
  nomePt String?
  slug   String         @unique
  movies ScrapedMovie[] @relation("LanguageToScrapedMovie")
}

model StreamingService {
  id             String       @id @default(cuid())
  service        String
  link           String
  scrapedMovieId String
  scrapedMovie   ScrapedMovie @relation(fields: [scrapedMovieId], references: [id], onDelete: Cascade)
}

model StreamingPlatform {
  id         String         @id @default(cuid())
  nome       String         @unique
  slug       String         @unique
  categoria  String
  isFeatured Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  movies     ScrapedMovie[] @relation("ScrapedMovieToStreamingPlatform")

  @@map("StreamingPlatform")
}
